{% extends 'base.html.twig' %}

{% block title %}Galerie - Le Jardin de Lan{% endblock %}

{% block body %}

    <!-- Header de la page -->
    <header class="bg-dark py-5">
        <div class="container px-4 px-lg-5 my-5">
            <div class="text-center text-white">
                <h1 class="display-4 fw-bolder">Notre Collection</h1>
                <p class="lead fw-normal text-white-50 mb-0">Découvrez nos plantes uniques</p>
            </div>
        </div>
    </header>

    <section class="py-5">
        <div class="container px-4 px-lg-5 mt-5">

            <!-- Barre de recherche -->
            <div class="row mb-4">
                <div class="col-lg-6 mx-auto">
                    <form class="d-flex" method="GET">
                        <input 
                            class="form-control me-2" 
                            type="search" 
                            name="search" 
                            placeholder="Rechercher une plante..." 
                            value="{{ search }}"
                            aria-label="Search">
                        <button class="btn btn-outline-dark" type="submit">Rechercher</button>
                    </form>
                </div>
            </div>

            <!-- Grille des plantes -->
            <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
                
                {% for plant in plants %}
                <div class="col mb-5">
                    <div class="card h-100">
                        <!-- Image -->
                        <img 
                            class="card-img-top" 
                            src="{{ plant.mainImage ? asset('uploads/plants/' ~ plant.mainImage) : asset('images/placeholder.jpg') }}" 
                            alt="{{ plant.commonName }}"
                            style="height: 250px; object-fit: cover;">

                        <div class="card-body p-4">
                            <div class="text-center">
                                <h5 class="fw-bolder">{{ plant.commonName }}</h5>
                                <span class="text-muted fst-italic">{{ plant.scientificName }}</span>
                                <p class="mt-2">{{ plant.shortDescription|slice(0, 80) }}...</p>
                            </div>
                        </div>

                        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                            <div class="text-center">
                                <span class="h5 fw-bold text-success">{{ plant.price|format_currency('EUR') }}</span><br>
                                {% if plant.isAvailable %}
                                    <a href="{{ path('plant_show', {slug: plant.slug}) }}" 
                                       class="btn btn-outline-dark mt-3">Voir les détails</a>
                                {% else %}
                                    <span class="btn btn-secondary mt-3 disabled">Indisponible</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% else %}
                    <div class="col-12 text-center">
                        <p>Aucune plante trouvée.</p>
                    </div>
                {% endfor %}

            </div>
        </div>
    </section>

{% endblock %}